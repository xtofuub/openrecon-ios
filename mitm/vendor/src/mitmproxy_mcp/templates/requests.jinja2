import json
import requests

def run_scraper():
    # Generated by mitmproxy-mcp
    # Note: requests does not impersonate browser fingerprints like curl_cffi
    with requests.Session() as client:
        client.verify = False  # Ignore SSL warnings
{% for flow in flows %}
        print(f"\n[Step {{ loop.index }}] Executing {{ flow.method }} {{ flow.url_preview }}...")
        headers_{{ loop.index0 }} = {{ to_json(flow.headers, indent=4) | replace('\n', '\n        ') }}
{% if flow.has_body %}
        data_{{ loop.index0 }} = {{ to_json(flow.body) }}
        try:
            response_{{ loop.index0 }} = client.request(
                method={{ to_json(flow.method) }},
                url={{ to_json(flow.url) }},
                headers=headers_{{ loop.index0 }},
                data=data_{{ loop.index0 }},
                timeout=30,
            )
            print(f"Status: {response_{{ loop.index0 }}.status_code}")
            # print(response_{{ loop.index0 }}.text[:200])
        except Exception as e:
            print(f"Error: {e}")
{% else %}
        try:
            response_{{ loop.index0 }} = client.request(
                method={{ to_json(flow.method) }},
                url={{ to_json(flow.url) }},
                headers=headers_{{ loop.index0 }},
                timeout=30,
            )
            print(f"Status: {response_{{ loop.index0 }}.status_code}")
            # print(response_{{ loop.index0 }}.text[:200])
        except Exception as e:
            print(f"Error: {e}")
{% endif %}

{% endfor %}

if __name__ == '__main__':
    import urllib3
    urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
    run_scraper()
