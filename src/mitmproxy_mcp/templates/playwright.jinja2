import asyncio
import json
from playwright.async_api import async_playwright

async def run_scraper():
    # Generated by mitmproxy-mcp
    async with async_playwright() as p:
        browser = await p.chromium.launch(headless=True)
        # preserve cookies and session state across requests
        context = await browser.new_context(ignore_https_errors=True)
        page = await context.new_page()
        page.set_default_timeout(30000)
{% for flow in flows %}
        print(f"\n[Step {{ loop.index }}] Executing {{ flow.method }} {{ flow.url_preview }}...")
        headers_{{ loop.index0 }} = {{ to_json(flow.headers, indent=4) | replace('\n', '\n        ') }}
{% if flow.is_navigation %}
        try:
            # try to navigate the page directly
            response_{{ loop.index0 }} = await page.goto({{ to_json(flow.url) }})
            print(f"Status: {response_{{ loop.index0 }}.status if response_{{ loop.index0 }} else 'Unknown'}")
            # content_{{ loop.index0 }} = await page.content()
            # print(content_{{ loop.index0 }}[:200])
        except Exception as e:
            print(f"Error: {e}")
{% else %}
{% if flow.has_body %}
        data_{{ loop.index0 }} = {{ to_json(flow.body) }}
        try:
            response_{{ loop.index0 }} = await context.request.fetch(
                {{ to_json(flow.url) }},
                method={{ to_json(flow.method) }},
                headers=headers_{{ loop.index0 }},
                data=data_{{ loop.index0 }},
            )
{% else %}
        try:
            response_{{ loop.index0 }} = await context.request.fetch(
                {{ to_json(flow.url) }},
                method={{ to_json(flow.method) }},
                headers=headers_{{ loop.index0 }},
            )
{% endif %}
            print(f"Status: {response_{{ loop.index0 }}.status}")
            # text_{{ loop.index0 }} = await response_{{ loop.index0 }}.text()
            # print(text_{{ loop.index0 }}[:200])
        except Exception as e:
            print(f"Error: {e}")
{% endif %}

{% endfor %}
        await browser.close()

if __name__ == '__main__':
    asyncio.run(run_scraper())
