import asyncio
import json
import aiohttp

async def run_scraper():
    # Generated by mitmproxy-mcp
    # Note: aiohttp does not impersonate browser fingerprints like curl_cffi
    timeout = aiohttp.ClientTimeout(total=30)
    connector = aiohttp.TCPConnector(verify_ssl=False)
    async with aiohttp.ClientSession(connector=connector, timeout=timeout) as client:
{% for flow in flows %}
        print(f"\n[Step {{ loop.index }}] Executing {{ flow.method }} {{ flow.url_preview }}...")
        headers_{{ loop.index0 }} = {{ to_json(flow.headers, indent=4) | replace('\n', '\n        ') }}
{% if flow.has_body %}
        data_{{ loop.index0 }} = {{ to_json(flow.body) }}
        try:
            async with client.request({{ to_json(flow.method) }}, url={{ to_json(flow.url) }}, headers=headers_{{ loop.index0 }}, data=data_{{ loop.index0 }}) as response_{{ loop.index0 }}:
                print(f"Status: {response_{{ loop.index0 }}.status}")
                text_{{ loop.index0 }} = await response_{{ loop.index0 }}.text()
                # print(text_{{ loop.index0 }}[:200])
        except Exception as e:
            print(f"Error: {e}")
{% else %}
        try:
            async with client.request({{ to_json(flow.method) }}, url={{ to_json(flow.url) }}, headers=headers_{{ loop.index0 }}) as response_{{ loop.index0 }}:
                print(f"Status: {response_{{ loop.index0 }}.status}")
                text_{{ loop.index0 }} = await response_{{ loop.index0 }}.text()
                # print(text_{{ loop.index0 }}[:200])
        except Exception as e:
            print(f"Error: {e}")
{% endif %}

{% endfor %}

if __name__ == '__main__':
    asyncio.run(run_scraper())
